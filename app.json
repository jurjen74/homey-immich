            "title": {
              "en": "Free space (GB)",
              "nl": "Vrije ruimte (GB)"
            },
            "example": 12.5
          }
        ],
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=immich"
          },
          {
            "name": "threshold",
            "type": "number",
            "title": {
              "en": "Threshold (GB)",
              "nl": "Drempelwaarde (GB)"
