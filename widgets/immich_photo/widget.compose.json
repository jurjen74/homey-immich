{
  "name": { "en": "Immich Photo", "nl": "Immich Foto" },
  "devices": {
    "type": "app",
    "singular": true,
    "filter": {
      "capabilities": "immich_photo_count"
    }
  },
  "settings": [
    {
      "id": "aspect",
      "type": "dropdown",
      "label": { "en": "Widget shape", "nl": "Widgetvorm" },
      "value": "landscape",
      "values": [
        { "id": "square",    "label": { "en": "Square (1:1)",      "nl": "Vierkant (1:1)" } },
        { "id": "landscape", "label": { "en": "Landscape (3:2)",   "nl": "Liggend (3:2)" } },
        { "id": "wide",      "label": { "en": "Wide (16:9)",       "nl": "Breed (16:9)" } },
        { "id": "portrait",  "label": { "en": "Portrait (2:3)",    "nl": "Staand (2:3)" } },
        { "id": "tall",      "label": { "en": "Tall (9:16)",       "nl": "Hoog (9:16)" } }
      ]
    },
    {
      "id": "fit",
      "type": "dropdown",
      "label": { "en": "Photo fit", "nl": "Foto-uitsnede" },
      "value": "cover",
      "values": [
        { "id": "cover",   "label": { "en": "Fill (crop edges)",       "nl": "Vullen (randen bijsnijden)" } },
        { "id": "contain", "label": { "en": "Fit (show whole photo)",  "nl": "Passend (hele foto tonen)" } }
      ]
    },
    {
      "id": "album",
      "type": "autocomplete",
      "label": { "en": "Album", "nl": "Album" }
    },
    {
      "id": "mode",
      "type": "dropdown",
      "label": { "en": "Photo source", "nl": "Fotobron" },
      "value": "random",
      "values": [
        { "id": "random", "label": { "en": "Random photo", "nl": "Willekeurige foto" } },
        { "id": "latest", "label": { "en": "Latest upload", "nl": "Nieuwste upload" } },
        { "id": "memory", "label": { "en": "Today's memory", "nl": "Herinnering van vandaag" } }
      ]
    },
    {
      "id": "refresh_interval",
      "type": "number",
      "label": { "en": "Refresh interval (seconds)", "nl": "Verversingsinterval (seconden)" },
      "value": 60,
      "min": 10,
      "max": 3600,
      "step": 1
    },
    {
      "id": "show_metadata",
      "type": "checkbox",
      "label": { "en": "Show filename and date", "nl": "Bestandsnaam en datum tonen" },
      "value": true
    }
  ],
  "api": {
    "getPhoto": {
      "method": "GET",
      "path": "/photo"
    }
  }
}
