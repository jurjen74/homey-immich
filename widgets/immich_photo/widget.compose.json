{
  "name": { "en": "Immich Photo", "nl": "Immich Foto" },
  "height": 220,
  "settings": [
    {
      "id": "device",
      "type": "autocomplete",
      "title": { "en": "Device", "nl": "Apparaat" }
    },
    {
      "id": "mode",
      "type": "dropdown",
      "title": { "en": "Photo source", "nl": "Fotobron" },
      "values": [
        { "id": "random", "label": { "en": "Random photo", "nl": "Willekeurige foto" } },
        { "id": "latest", "label": { "en": "Latest upload", "nl": "Nieuwste upload" } },
        { "id": "memory", "label": { "en": "Today's memory", "nl": "Herinnering van vandaag" } }
      ],
      "value": "random"
    },
    {
      "id": "refresh_interval",
      "type": "number",
      "title": { "en": "Refresh interval (seconds)", "nl": "Verversingsinterval (seconden)" },
      "value": 60,
      "attr": { "min": 10, "max": 3600 }
    },
    {
      "id": "show_metadata",
      "type": "checkbox",
      "title": { "en": "Show filename and date", "nl": "Bestandsnaam en datum tonen" },
      "value": true
    }
  ],
  "api": {
    "getPhoto": {
      "method": "GET",
      "path": "/photo"
    }
  }
}
